# backend/.env
# Server Configuration
PORT=8080
ENVIRONMENT=development
READ_TIMEOUT=30s
WRITE_TIMEOUT=30s
IDLE_TIMEOUT=60s

# Blockchain Configuration
BLOCKCHAIN_RPC_URL=http://localhost:8545
CHAIN_ID=31337
DID_REGISTRY_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
ZKP_VERIFIER_ADDRESS=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512
CREDENTIAL_NFT_ADDRESS=0x9fE46736679d2D9a65F0992F2272dE9f3c7fa6e0
PRIVATE_KEY=your_private_key_here

# IPFS Configuration
IPFS_HOST=localhost
IPFS_PORT=5001
IPFS_PROTOCOL=http
PINATA_API_KEY=your_pinata_key
PINATA_API_SECRET=your_pinata_secret

# Security
RATE_LIMIT=100
JWT_SECRET=your-secret-key
API_KEY=your-api-key

# ZKP
CIRCUIT_PATH=../circuits
VERIFICATION_KEY_PATH=../circuits/verification_key.json
