{
  "name": "did-protocol-frontend",
  "version": "1.0.0",
  "description": "Decentralized Identity Protocol with Zero-Knowledge Proofs",
  "author": "DID Protocol Team",
  "license": "MIT",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "vite --host",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --ext js,jsx --fix",
    "format": "prettier --write 'src/**/*.{js,jsx,css,json}'",
    "preview:build": "npm run build && npm run preview",
    "clean": "rm -rf dist node_modules/.vite",
    "circuits:compile": "bash scripts/compile-circuits.sh",
    "circuits:setup": "bash scripts/setup-zkp.sh",
    "contracts:compile": "hardhat compile",
    "contracts:deploy": "hardhat run scripts/deploy.js --network localhost",
    "contracts:deploy:testnet": "hardhat run scripts/deploy.js --network sepolia",
    "ipfs:start": "ipfs daemon",
    "ganache:start": "ganache --port 8545 --chainId 1337",
    "hardhat:node": "hardhat node",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "prepare": "husky install"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "ethers": "^5.7.2",
    "@metamask/providers": "^15.0.0",
    "ipfs-http-client": "^60.0.0",
    "snarkjs": "^0.7.0",
    "buffer": "^6.0.3",
    "axios": "^1.6.2",
    "date-fns": "^2.30.0",
    "qrcode.react": "^3.1.0",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^4.12.0",
    "react-spinners": "^0.13.8",
    "zustand": "^4.4.7",
    "immer": "^10.0.3",
    "uuid": "^9.0.1",
    "crypto-browserify": "^3.12.0",
    "stream-browserify": "^3.0.0",
    "process": "^0.11.10"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "vite": "^5.0.8",
    "vitest": "^1.0.4",
    "@vitest/ui": "^1.0.4",
    "@vitest/coverage-v8": "^1.0.4",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "prettier": "^3.1.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "hardhat": "^2.19.4",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomiclabs/hardhat-ethers": "^2.2.3",
    "@nomiclabs/hardhat-waffle": "^2.0.6",
    "chai": "^4.3.10",
    "mocha": "^10.2.0",
    "ganache": "^7.9.1",
    "circom": "^2.1.6",
    "circomlib": "^2.0.5",
    "snarkjs": "^0.7.0",
    "typescript": "^5.2.2",
    "vite-plugin-node-polyfills": "^0.17.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json}": [
      "prettier --write"
    ]
  },
  "proxy": "http://localhost:8545"
}
