# IPFS Configuration
REACT_APP_IPFS_HOST=ipfs.infura.io
REACT_APP_IPFS_PORT=5001
REACT_APP_IPFS_PROTOCOL=https

# Pinata (optional, for pinning)
REACT_APP_PINATA_API_KEY=your_pinata_api_key
REACT_APP_PINATA_API_SECRET=your_pinata_api_secret

# Infura IPFS (optional)
REACT_APP_INFURA_IPFS_PROJECT_ID=your_project_id
REACT_APP_INFURA_IPFS_PROJECT_SECRET=your_project_secret
