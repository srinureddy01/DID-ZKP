# frontend/.env
# ==================== Environment Configuration ====================

# Node Environment
NODE_ENV=development

# ==================== Contract Addresses ====================
# Deploy your contracts and update these addresses
VITE_DID_REGISTRY_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
VITE_ZKP_VERIFIER_ADDRESS=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512
VITE_CREDENTIAL_NFT_ADDRESS=0x9fE46736679d2D9a65F0992F2272dE9f3c7fa6e0

# ==================== Network Configuration ====================
VITE_CHAIN_ID=31337
VITE_CHAIN_NAME=Hardhat Local
VITE_CHAIN_RPC_URL=http://localhost:8545
VITE_CHAIN_CURRENCY_SYMBOL=ETH
VITE_CHAIN_EXPLORER_URL=

# ==================== IPFS Configuration ====================
VITE_IPFS_HOST=ipfs.infura.io
VITE_IPFS_PORT=5001
VITE_IPFS_PROTOCOL=https
VITE_IPFS_GATEWAY=https://ipfs.io/ipfs/

# Pinata (for pinning)
VITE_PINATA_API_KEY=your_pinata_api_key_here
VITE_PINATA_API_SECRET=your_pinata_api_secret_here

# Infura IPFS (optional)
VITE_INFURA_IPFS_PROJECT_ID=your_infura_project_id
VITE_INFURA_IPFS_PROJECT_SECRET=your_infura_project_secret

# ==================== ZKP Circuit Paths ====================
VITE_CIRCUITS_BASE_URL=/circuits
VITE_AGE_PROOF_WASM=/circuits/AgeProof.wasm
VITE_AGE_PROOF_ZKEY=/circuits/AgeProof_final.zkey
VITE_IDENTITY_PROOF_WASM=/circuits/IdentityProof.wasm
VITE_IDENTITY_PROOF_ZKEY=/circuits/IdentityProof_final.zkey

# ==================== API Configuration ====================
VITE_API_BASE_URL=http://localhost:8080/api
VITE_WS_URL=ws://localhost:8080/ws

# ==================== Feature Flags ====================
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG_LOGS=true
VITE_ENABLE_MOCK_DATA=false

# ==================== Security ====================
VITE_SESSION_TIMEOUT_MINUTES=30
VITE_MAX_ATTEMPT_AGE_PROOF=5
VITE_RATE_LIMIT_REQUESTS=100
