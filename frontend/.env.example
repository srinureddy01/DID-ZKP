# frontend/.env.example
# Copy this file to .env and update the values

# Contract Addresses (update after deployment)
VITE_DID_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
VITE_ZKP_VERIFIER_ADDRESS=0x0000000000000000000000000000000000000000
VITE_CREDENTIAL_NFT_ADDRESS=0x0000000000000000000000000000000000000000

# Network Configuration
VITE_CHAIN_ID=31337
VITE_CHAIN_NAME=Hardhat Local
VITE_CHAIN_RPC_URL=http://localhost:8545
VITE_CHAIN_CURRENCY_SYMBOL=ETH

# IPFS Configuration
VITE_IPFS_HOST=ipfs.infura.io
VITE_PINATA_API_KEY=
VITE_PINATA_API_SECRET=

# API Configuration
VITE_API_BASE_URL=http://localhost:8080/api

# Feature Flags
VITE_ENABLE_DEBUG_LOGS=true
VITE_ENABLE_MOCK_DATA=false
